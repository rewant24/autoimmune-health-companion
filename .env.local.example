# Convex (`npx convex dev` writes the real values into .env.local)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Vercel AI Gateway — used by the Stage-1 metric extraction route
# (app/api/check-in/extract/route.ts). Get from Vercel project settings →
# AI Gateway. Never commit the real value. Server-only.
AI_GATEWAY_API_KEY=

# Sarvam AI — server-only. Never NEXT_PUBLIC_*. Used by
# app/api/transcribe/route.ts (STT) and app/api/speak/route.ts (TTS).
SARVAM_API_KEY=

# Voice provider selectors. Default 'web-speech' for dev/tests.
# Set both to 'sarvam' in Vercel Production + Preview to route through
# the Sarvam streaming proxy.
VOICE_PROVIDER=web-speech
VOICE_TTS_PROVIDER=web-speech
